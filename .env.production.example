APP_NAME="QA365 - Quality Assurance Platform"
APP_ENV=production
APP_KEY=base64:CHANGE_THIS_IN_PRODUCTION
APP_DEBUG=false
APP_TIMEZONE=America/Bogota
APP_URL=https://your-domain.com

# Database - MySQL/PostgreSQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=qa365_production
DB_USERNAME=qa365_user
DB_PASSWORD=STRONG_PASSWORD_HERE

# Cache & Sessions - Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Queue
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@domain.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@qa365.com
MAIL_FROM_NAME="${APP_NAME}"

# AI Provider (Gemini recommended)
AI_PROVIDER=gemini
AI_GEMINI_API_KEY=your-production-api-key
AI_GEMINI_MODEL=gemini-2.0-flash-exp
AI_GEMINI_TEMPERATURE=0.3

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning
